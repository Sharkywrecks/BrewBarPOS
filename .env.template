# BrewBar POS — Environment Variables
# Copy this file to .env and fill in the values.

# MySQL
MYSQL_ROOT_PASSWORD=brewbar_root
MYSQL_DATABASE=brewbar
MYSQL_USER=brewbar
MYSQL_PASSWORD=brewbar_dev

# Redis
REDIS_PASSWORD=

# API
ASPNETCORE_ENVIRONMENT=Development
CONNECTION_STRING=Server=localhost;Port=3306;Database=brewbar;User=brewbar;Password=brewbar_dev;
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters
JWT_ISSUER=BrewBarAPI
JWT_AUDIENCE=BrewBarClient

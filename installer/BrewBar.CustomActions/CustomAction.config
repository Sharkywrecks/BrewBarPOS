<?xml version="1.0" encoding="utf-8"?>
<!--
  Bundled inside BrewBar.CustomActions.CA.dll by WiX DTF MakeSfxCA. SFXCA's
  native loader extracts this file to a temp dir alongside the managed CA dll
  and reads it to decide which CLR to host. The literal filename
  CustomAction.config is required - SFXCA does not look for the dll-specific
  app.config name. The file is included in the SFXCA bundle via the Content
  item in BrewBar.CustomActions.csproj (the WiX DTF targets pass @(Content)
  through to MakeSfxCA).

  Without this file, SFXCA falls back to its compiled-in default of
  v2.0.50727 (.NET Framework 2.0/3.5 CLR), which is an OPTIONAL feature on
  Windows 10/11 and absent on most modern installs - producing
  `SFXCA: Failed to get requested CLR info. Error code 0x80131700`
  (CLR_E_SHIM_RUNTIMELOAD) and aborting the install with MSI 1603 before any
  custom action body can run.

  useLegacyV2RuntimeActivationPolicy is required because SFXCA uses the
  legacy mscoree CorBindToRuntimeEx activation API; without it the loader
  refuses to host a v4 CLR even when supportedRuntime requests one.
-->
<configuration>
  <startup useLegacyV2RuntimeActivationPolicy="true">
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
</configuration>

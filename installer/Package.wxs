<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="BrewBar POS"
           Manufacturer="BrewBar"
           Version="$(var.ProductVersion)"
           UpgradeCode="8F4E2A1B-3C5D-4E6F-A7B8-9C0D1E2F3A4B"
           Compressed="yes"
           InstallerVersion="500"
           Scope="perMachine">

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of BrewBar POS is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Close running BrewBar processes before install/upgrade/uninstall -->
    <util:CloseApplication Id="CloseBrewBarPOS"
                           Target="BrewBar POS.exe"
                           RebootPrompt="no"
                           CloseMessage="yes"
                           TerminateProcess="1"
                           Timeout="5" />
    <util:CloseApplication Id="CloseBrewBarAPI"
                           Target="BrewBar.API.exe"
                           RebootPrompt="no"
                           CloseMessage="yes"
                           TerminateProcess="1"
                           Timeout="5" />

    <!-- License (required by WixUI_FeatureTree) -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- Deployment mode property: "standalone" or "terminal" -->
    <Property Id="DEPLOY_MODE" Value="standalone" Secure="yes" />
    <Property Id="API_URL" Value="https://your-server.com" Secure="yes" />

    <UI>
      <!-- Install wizard UI with feature tree (lets users pick shortcuts).
           Must be inside <UI> so custom <Publish> overrides merge correctly. -->
      <ui:WixUI Id="WixUI_FeatureTree" />
      <!-- ================================================================
           INSTALL: Deployment Mode dialog
           Choose standalone (local API) or terminal (remote API).
           ================================================================ -->
      <Dialog Id="DeployModeDlg" Width="370" Height="270" Title="BrewBar POS — Deployment Mode">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Deployment Mode" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="Choose how this terminal will connect to the BrewBar backend." />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <Control Id="StandaloneRadio" Type="RadioButtonGroup" X="25" Y="55" Width="320" Height="80"
                 Property="DEPLOY_MODE">
          <RadioButtonGroup Property="DEPLOY_MODE">
            <RadioButton Value="standalone" X="0" Y="0" Width="320" Height="18"
                         Text="Standalone — runs its own local server and database (single machine)" />
            <RadioButton Value="terminal" X="0" Y="30" Width="320" Height="18"
                         Text="Terminal — connects to an existing BrewBar server on your network" />
          </RadioButtonGroup>
        </Control>

        <Control Id="ApiUrlLabel" Type="Text" X="25" Y="150" Width="320" Height="12"
                 NoPrefix="yes" Text="Server API URL (terminal mode only):" />
        <Control Id="ApiUrlEdit" Type="Edit" X="25" Y="165" Width="320" Height="18"
                 Property="API_URL" />
        <Control Id="ApiUrlHint" Type="Text" X="25" Y="188" Width="320" Height="12"
                 NoPrefix="yes" Text="e.g. https://pos-api.yourdomain.com or http://192.168.1.100:5000" />

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back">
          <Publish Event="NewDialog" Value="CustomizeDlg" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="Next">
          <!-- Standalone → business setup dialog. Terminal → skip to verify. -->
          <Publish Event="NewDialog" Value="MenuImportDlg" Condition="DEPLOY_MODE = &quot;standalone&quot;" Order="1" />
          <Publish Event="NewDialog" Value="DeleteDataDlg" Condition="DEPLOY_MODE = &quot;terminal&quot;" Order="2" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- ================================================================
           INSTALL: Business Setup + Menu Import dialog (standalone only)
           ================================================================ -->
      <Dialog Id="MenuImportDlg" Width="370" Height="270" Title="BrewBar POS — Business Setup">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Business Setup" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="Configure your business details and optionally import a menu." />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <!-- Store Name -->
        <Control Id="StoreNameLabel" Type="Text" X="25" Y="52" Width="120" Height="12"
                 NoPrefix="yes" Text="Store Name:" />
        <Control Id="StoreNameEdit" Type="Edit" X="150" Y="50" Width="195" Height="18"
                 Property="STORE_NAME" />

        <!-- Tax Rate -->
        <Control Id="TaxRateLabel" Type="Text" X="25" Y="76" Width="120" Height="12"
                 NoPrefix="yes" Text="Tax Rate (e.g. 0.0875):" />
        <Control Id="TaxRateEdit" Type="Edit" X="150" Y="74" Width="80" Height="18"
                 Property="TAX_RATE" />

        <Control Id="Intro" Type="Text" X="25" Y="98" Width="320" Height="25"
                 NoPrefix="yes"
                 Text="If you have a menu spreadsheet, browse for it below. Leave blank to start with the sample menu." />

        <Control Id="FormatTitle" Type="Text" X="25" Y="85" Width="320" Height="12"
                 NoPrefix="yes" Text="Expected Excel format (3 sheets):" />

        <Control Id="FormatDetails" Type="Text" X="25" Y="98" Width="320" Height="60"
                 NoPrefix="yes"
                 Text="Sheet 'Products': Category | Product Name | Description | Price | Available&#13;&#10;Sheet 'Modifiers': Modifier Name | Required | Allow Multiple | Option Name | Option Price&#13;&#10;Sheet 'Product Modifiers': Product Name | Modifier Name&#13;&#10;&#13;&#10;A ready-to-fill template (menu-template.xlsx) will be placed in the install directory." />

        <Control Id="FileLabel" Type="Text" X="25" Y="168" Width="320" Height="12"
                 NoPrefix="yes" Text="Menu file path (optional):" />

        <Control Id="MenuFilePath" Type="Edit" X="25" Y="182" Width="275" Height="18"
                 Property="MENU_FILE" />
        <Control Id="BrowseBtn" Type="PushButton" X="305" Y="182" Width="45" Height="18" Text="Browse">
          <Publish Property="_BrowseProperty" Value="MENU_FILE" Order="1" />
          <Publish Event="SpawnDialog" Value="BrowseDlg" Order="2" />
        </Control>

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back">
          <Publish Event="NewDialog" Value="DeployModeDlg" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="Next">
          <Publish Event="NewDialog" Value="DeleteDataDlg" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Wire: CustomizeDlg → DeployModeDlg → MenuImportDlg (standalone) or DeleteDataDlg (terminal)
           Only during install (not removal). -->
      <Publish Dialog="CustomizeDlg" Control="Next" Event="NewDialog" Value="DeployModeDlg"
               Condition="NOT REMOVE~=&quot;ALL&quot;" Order="9000" />
      <!-- VerifyReadyDlg Back: go to DeleteDataDlg during install -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="DeleteDataDlg"
               Condition="NOT REMOVE~=&quot;ALL&quot;" Order="9000" />

      <!-- ================================================================
           Data Options dialog — checkbox to delete previous data.
           Shown during BOTH install (upgrade/reinstall) and uninstall.
           ================================================================ -->
      <Dialog Id="DeleteDataDlg" Width="370" Height="270" Title="BrewBar POS — Data Options">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Data Options" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="20"
                 Transparent="yes" NoPrefix="yes"
                 Text="Choose whether to keep or remove existing application data." />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <Control Id="Info" Type="Text" X="25" Y="60" Width="320" Height="40"
                 NoPrefix="yes"
                 Text="The database containing your orders, menu, and settings is stored in your AppData folder. Check the box below to permanently delete it and start fresh." />

        <Control Id="DeleteDataCheck" Type="CheckBox" X="25" Y="110" Width="320" Height="18"
                 Property="DELETE_DATA" CheckBoxValue="1"
                 Text="Delete all application data (orders, menu, settings)" />

        <Control Id="Warning" Type="Text" X="25" Y="135" Width="320" Height="20"
                 NoPrefix="yes"
                 Text="Warning: This cannot be undone." />

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back">
          <!-- During install: go back to MenuImportDlg (standalone) or DeployModeDlg (terminal) -->
          <Publish Event="NewDialog" Value="MenuImportDlg" Condition="NOT REMOVE~=&quot;ALL&quot; AND DEPLOY_MODE = &quot;standalone&quot;" Order="1" />
          <Publish Event="NewDialog" Value="DeployModeDlg" Condition="NOT REMOVE~=&quot;ALL&quot; AND DEPLOY_MODE = &quot;terminal&quot;" Order="2" />
          <!-- During uninstall: go back to VerifyReadyDlg -->
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="REMOVE~=&quot;ALL&quot;" Order="3" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="Next">
          <!-- During install: proceed to VerifyReadyDlg -->
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="NOT REMOVE~=&quot;ALL&quot;" Order="1" />
          <!-- During uninstall: proceed with removal -->
          <Publish Event="EndDialog" Value="Return" Condition="REMOVE~=&quot;ALL&quot;" Order="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Wire: VerifyReadyDlg "Remove" button goes to DeleteDataDlg during uninstall -->
      <Publish Dialog="VerifyReadyDlg" Control="InstallNoShield" Event="NewDialog" Value="DeleteDataDlg"
               Condition="REMOVE~=&quot;ALL&quot;" Order="9000" />

      <!-- Wire: ExitDialog checkbox fires the launch action -->
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <!-- Install directory -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="BrewBarPOS" />
    </StandardDirectory>

    <!-- Harvest Electron output -->
    <ComponentGroup Id="ElectronFiles" Directory="INSTALLFOLDER">
      <Files Include="..\build\electron\win-unpacked\**" />
    </ComponentGroup>

    <!-- Menu template bundled in install directory -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="MenuTemplate" Guid="D4E5F6A7-B8C9-0123-DEF0-234567890ABC">
        <File Id="MenuTemplateFile"
              Source="..\server\src\BrewBar.API\Resources\menu-template.xlsx"
              Name="menu-template.xlsx" />
        <RegistryValue Root="HKLM"
                       Key="Software\BrewBar\POS"
                       Name="menuTemplate"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!--
      Optional menu import: pass MENU_FILE on command line to import a menu on first launch.
      Example: msiexec /i BrewBar.Installer.msi MENU_FILE="C:\Users\me\my-menu.xlsx"
      The file is copied into the API resources directory as menu-import.xlsx.
      The Electron app detects it on first launch and imports it via the API.
    -->
    <Property Id="MENU_FILE" Secure="yes" />

    <!-- Business settings — set during install, written to JSON config for first-launch import -->
    <Property Id="STORE_NAME" Value="BrewBar" Secure="yes" />
    <Property Id="TAX_RATE" Value="0.0875" Secure="yes" />

    <!-- Write deployment config for Electron to read on startup -->
    <CustomAction Id="WriteDeploymentJson"
                  Directory="INSTALLFOLDER"
                  ExeCommand='cmd.exe /c echo {"mode":"[DEPLOY_MODE]","apiUrl":"[API_URL]","apiPort":5000} > "[INSTALLFOLDER]deployment.json"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Write business settings JSON for first-launch import (standalone only) -->
    <CustomAction Id="WriteSettingsJson"
                  Directory="INSTALLFOLDER"
                  ExeCommand='cmd.exe /c echo {"storeName":"[STORE_NAME]","taxRate":[TAX_RATE]} > "[INSTALLFOLDER]resources\api\install-settings.json"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />
    <SetProperty Id="MENU_FILE_DEST" After="CostFinalize" Value="[INSTALLFOLDER]resources\api\menu-import.xlsx" />

    <CustomAction Id="CopyMenuFile"
                  Directory="INSTALLFOLDER"
                  ExeCommand='cmd.exe /c if not "[MENU_FILE]"=="" copy /Y "[MENU_FILE]" "[INSTALLFOLDER]resources\api\menu-import.xlsx"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!--
      Optional: delete user data (database) on uninstall.
      Default is OFF — user must explicitly opt in via:
        msiexec /x {ProductCode} DELETE_DATA=1
      or via the checkbox in the uninstall confirmation UI.
    -->
    <Property Id="DELETE_DATA" Value="0" Secure="yes" />

    <CustomAction Id="DeleteUserData"
                  Directory="INSTALLFOLDER"
                  ExeCommand='cmd.exe /c rmdir /s /q "%APPDATA%\brewbar-pos-desktop"'
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="WriteDeploymentJson" After="InstallFiles" />
      <Custom Action="WriteSettingsJson" After="WriteDeploymentJson" Condition="DEPLOY_MODE = &quot;standalone&quot;" />
      <Custom Action="CopyMenuFile" After="WriteSettingsJson" Condition="MENU_FILE AND DEPLOY_MODE = &quot;standalone&quot;" />
      <Custom Action="DeleteUserData" After="RemoveFiles" Condition="REMOVE~=&quot;ALL&quot; AND DELETE_DATA=&quot;1&quot;" />
    </InstallExecuteSequence>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="BrewBarStartMenu" Name="BrewBar POS">
        <Component Id="StartMenuShortcut" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
          <Shortcut Id="BrewBarShortcut"
                    Name="BrewBar POS"
                    Target="[INSTALLFOLDER]BrewBar POS.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RegistryValue Root="HKCU"
                         Key="Software\BrewBar\POS"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
          <RemoveFolder Id="RemoveBrewBarStartMenu" On="uninstall" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Desktop shortcut -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <Shortcut Id="BrewBarDesktopShortcut"
                  Name="BrewBar POS"
                  Target="[INSTALLFOLDER]BrewBar POS.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\BrewBar\POS"
                       Name="desktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Taskbar pin shortcut (placed on desktop with taskbar-pin-friendly name) -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="TaskbarPinHelper" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <Shortcut Id="BrewBarTaskbarShortcut"
                  Name="BrewBar POS - Pin to Taskbar"
                  Description="Drag this shortcut to the taskbar to pin BrewBar POS"
                  Target="[INSTALLFOLDER]BrewBar POS.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\BrewBar\POS"
                       Name="taskbarHelper"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Launch application checkbox on the installer exit dialog -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch BrewBar POS" />
    <Property Id="WixShellExecTarget" Value="[INSTALLFOLDER]BrewBar POS.exe" />
    <CustomAction Id="LaunchApplication"
                  DllEntry="WixShellExec"
                  Impersonate="yes"
                  BinaryRef="Wix4UtilCA_X86" />

    <!-- Features shown in the feature-tree UI -->
    <Feature Id="MainApplication" Title="BrewBar POS" Description="Core application files (required)."
             Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="ElectronFiles" />
      <ComponentRef Id="MenuTemplate" />
    </Feature>

    <Feature Id="StartMenuShortcutFeature" Title="Start Menu Shortcut"
             Description="Add a shortcut to the Windows Start Menu." Level="1" AllowAbsent="yes">
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Feature Id="DesktopShortcutFeature" Title="Desktop Shortcut"
             Description="Add a shortcut to the Desktop." Level="1" AllowAbsent="yes">
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <Feature Id="TaskbarPinFeature" Title="Taskbar Pin Helper"
             Description="Place a helper shortcut on the Desktop that you can drag to the taskbar."
             Level="2" AllowAbsent="yes">
      <ComponentRef Id="TaskbarPinHelper" />
    </Feature>

  </Package>
</Wix>

<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="BrewBar POS"
           Manufacturer="BrewBar"
           Version="$(var.ProductVersion)"
           UpgradeCode="8F4E2A1B-3C5D-4E6F-A7B8-9C0D1E2F3A4B"
           Compressed="yes"
           InstallerVersion="500"
           Scope="perMachine">

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of BrewBar POS is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Close running BrewBar processes before install/upgrade/uninstall -->
    <util:CloseApplication Id="CloseBrewBarPOS"
                           Target="BrewBar POS.exe"
                           RebootPrompt="no"
                           CloseMessage="yes"
                           TerminateProcess="1"
                           Timeout="5" />
    <util:CloseApplication Id="CloseBrewBarAPI"
                           Target="BrewBar.API.exe"
                           RebootPrompt="no"
                           CloseMessage="yes"
                           TerminateProcess="1"
                           Timeout="5" />

    <!-- License (required by WixUI_FeatureTree) -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- Deployment mode property: "standalone" or "terminal" -->
    <Property Id="DEPLOY_MODE" Value="standalone" Secure="yes" />
    <Property Id="API_URL" Value="https://your-server.com" Secure="yes" />

    <UI>
      <TextStyle Id="WixUI_Font_Bold" FaceName="Tahoma" Size="8" Bold="yes" />

      <!-- Install wizard UI with feature tree (lets users pick shortcuts).
           Must be inside <UI> so custom <Publish> overrides merge correctly. -->
      <ui:WixUI Id="WixUI_FeatureTree" />
      <!-- ================================================================
           INSTALL: Deployment Mode dialog
           Choose standalone (local API) or terminal (remote API).
           ================================================================ -->
      <Dialog Id="DeployModeDlg" Width="370" Height="270" Title="BrewBar POS — Deployment Mode">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Deployment Mode" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="Choose how this terminal will connect to the BrewBar backend." />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <Control Id="StandaloneRadio" Type="RadioButtonGroup" X="25" Y="55" Width="320" Height="80"
                 Property="DEPLOY_MODE">
          <RadioButtonGroup Property="DEPLOY_MODE">
            <RadioButton Value="standalone" X="0" Y="0" Width="320" Height="18"
                         Text="Standalone — runs its own local server and database (single machine)" />
            <RadioButton Value="terminal" X="0" Y="30" Width="320" Height="18"
                         Text="Terminal — connects to an existing BrewBar server on your network" />
          </RadioButtonGroup>
        </Control>

        <Control Id="ApiUrlLabel" Type="Text" X="25" Y="150" Width="320" Height="12"
                 NoPrefix="yes" Text="Server API URL (terminal mode only):" />
        <Control Id="ApiUrlEdit" Type="Edit" X="25" Y="165" Width="320" Height="18"
                 Property="API_URL" />
        <Control Id="ApiUrlHint" Type="Text" X="25" Y="188" Width="320" Height="12"
                 NoPrefix="yes" Text="e.g. https://pos-api.yourdomain.com or http://192.168.1.100:5000" />

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back">
          <Publish Event="NewDialog" Value="CustomizeDlg" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="Next">
          <!-- Standalone → business setup dialog. Terminal → skip to verify. -->
          <Publish Event="NewDialog" Value="BusinessSetupDlg" Condition="DEPLOY_MODE = &quot;standalone&quot;" Order="1" />
          <Publish Event="NewDialog" Value="DeleteDataDlg" Condition="DEPLOY_MODE = &quot;terminal&quot;" Order="2" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- ================================================================
           INSTALL: Business Setup dialog (standalone only)
           ================================================================ -->
      <Dialog Id="BusinessSetupDlg" Width="370" Height="240" Title="BrewBar POS — Business Setup">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Business Setup" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="Configure your business details and admin account." />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <!-- Store Name -->
        <Control Id="StoreNameLabel" Type="Text" X="25" Y="52" Width="120" Height="12"
                 NoPrefix="yes" Text="Store Name:" />
        <Control Id="StoreNameEdit" Type="Edit" X="150" Y="50" Width="195" Height="18"
                 Property="STORE_NAME" />

        <!-- Tax Rate (displayed as percentage, stored/converted to decimal) -->
        <Control Id="TaxRateLabel" Type="Text" X="25" Y="76" Width="120" Height="12"
                 NoPrefix="yes" Text="Tax Rate Percent (e.g. 15):" />
        <Control Id="TaxRateEdit" Type="Edit" X="150" Y="74" Width="50" Height="18"
                 Property="TAX_RATE_PCT" />
        <Control Id="TaxRateSuffix" Type="Text" X="203" Y="78" Width="20" Height="12"
                 NoPrefix="yes" Text="%" />

        <!-- Currency -->
        <Control Id="CurrencyLabel" Type="Text" X="25" Y="100" Width="120" Height="12"
                 NoPrefix="yes" Text="Currency:" />
        <Control Id="CurrencyCombo" Type="ComboBox" X="150" Y="98" Width="80" Height="18"
                 Property="CURRENCY_CODE">
          <ComboBox Property="CURRENCY_CODE">
            <ListItem Value="SCR" Text="SCR" />
            <ListItem Value="USD" Text="USD" />
            <ListItem Value="EUR" Text="EUR" />
            <ListItem Value="GBP" Text="GBP" />
          </ComboBox>
        </Control>

        <!-- Admin Account — REQUIRED. Wizard "Next" is conditioned on all four
             fields being non-empty so the install can never produce an account
             with a blank password / PIN. There is no fallback to a default. -->
        <Control Id="AdminSectionLabel" Type="Text" X="25" Y="122" Width="320" Height="12"
                 NoPrefix="yes" Text="{\WixUI_Font_Bold}Admin Account (required)" />
        <Control Id="AdminNameLabel" Type="Text" X="25" Y="138" Width="60" Height="12"
                 NoPrefix="yes" Text="Name:" />
        <Control Id="AdminNameEdit" Type="Edit" X="90" Y="136" Width="100" Height="18"
                 Property="ADMIN_NAME" />
        <Control Id="AdminEmailLabel" Type="Text" X="195" Y="138" Width="40" Height="12"
                 NoPrefix="yes" Text="Email:" />
        <Control Id="AdminEmailEdit" Type="Edit" X="240" Y="136" Width="105" Height="18"
                 Property="ADMIN_EMAIL" />
        <Control Id="AdminPasswordLabel" Type="Text" X="25" Y="160" Width="60" Height="12"
                 NoPrefix="yes" Text="Password:" />
        <Control Id="AdminPasswordEdit" Type="Edit" X="90" Y="158" Width="100" Height="18"
                 Property="ADMIN_PASSWORD" Password="yes" />
        <Control Id="AdminPinLabel" Type="Text" X="195" Y="160" Width="40" Height="12"
                 NoPrefix="yes" Text="PIN:" />
        <Control Id="AdminPinEdit" Type="Edit" X="240" Y="158" Width="60" Height="18"
                 Property="ADMIN_PIN" Password="yes" />
        <Control Id="ValidationHint" Type="Text" X="25" Y="183" Width="320" Height="12"
                 NoPrefix="yes"
                 Text="All fields required. Password: 8+ chars, digit, lowercase, special char. PIN: 4-6 digits." />

        <Control Id="BottomLine" Type="Line" X="0" Y="204" Width="370" Height="0" />

        <Control Id="Back" Type="PushButton" X="180" Y="213" Width="56" Height="17" Text="Back">
          <Publish Event="NewDialog" Value="DeployModeDlg" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="213" Width="56" Height="17" Default="yes" Text="Next">
          <!-- Block advance unless all four admin fields are non-empty AND password
               is at least 6 chars AND pin is 4-6 chars. SpawnDialog the error
               otherwise. -->
          <Publish Event="SpawnDialog" Value="AdminFieldsRequiredDlg"
                   Condition="ADMIN_NAME=&quot;&quot; OR ADMIN_EMAIL=&quot;&quot; OR ADMIN_PASSWORD=&quot;&quot; OR ADMIN_PIN=&quot;&quot;"
                   Order="1" />
          <Publish Event="NewDialog" Value="DeleteDataDlg"
                   Condition="ADMIN_NAME&lt;&gt;&quot;&quot; AND ADMIN_EMAIL&lt;&gt;&quot;&quot; AND ADMIN_PASSWORD&lt;&gt;&quot;&quot; AND ADMIN_PIN&lt;&gt;&quot;&quot;"
                   Order="2" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="213" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Validation error dialog for empty admin fields. -->
      <Dialog Id="AdminFieldsRequiredDlg" Width="260" Height="100" Title="BrewBar POS"
              NoMinimize="yes">
        <Control Id="Message" Type="Text" X="20" Y="20" Width="220" Height="40"
                 NoPrefix="yes"
                 Text="All admin account fields are required: name, email, password, and PIN. Please go back and fill them in." />
        <Control Id="OK" Type="PushButton" X="100" Y="70" Width="60" Height="17"
                 Default="yes" Cancel="yes" Text="OK">
          <Publish Event="EndDialog" Value="Return" />
        </Control>
      </Dialog>

      <!-- Wire: CustomizeDlg → DeployModeDlg → BusinessSetupDlg (standalone) or DeleteDataDlg (terminal)
           Only during install (not removal). -->
      <Publish Dialog="CustomizeDlg" Control="Next" Event="NewDialog" Value="DeployModeDlg"
               Condition="NOT REMOVE~=&quot;ALL&quot;" Order="9000" />
      <!-- VerifyReadyDlg Back: go to DeleteDataDlg during install -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="DeleteDataDlg"
               Condition="NOT REMOVE~=&quot;ALL&quot;" Order="9000" />

      <!-- ================================================================
           Data Options dialog — checkbox to delete previous data.
           Shown during BOTH install (upgrade/reinstall) and uninstall.
           ================================================================ -->
      <Dialog Id="DeleteDataDlg" Width="370" Height="270" Title="BrewBar POS — Data Options">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Data Options" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="20"
                 Transparent="yes" NoPrefix="yes"
                 Text="Choose whether to keep or remove existing application data." />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <Control Id="Info" Type="Text" X="25" Y="60" Width="320" Height="40"
                 NoPrefix="yes"
                 Text="The database containing your orders, menu, and settings is stored in your AppData folder. Check the box below to permanently delete it and start fresh." />

        <Control Id="DeleteDataCheck" Type="CheckBox" X="25" Y="110" Width="320" Height="18"
                 Property="DELETE_DATA" CheckBoxValue="1"
                 Text="Delete all application data (orders, menu, settings)" />

        <Control Id="Warning" Type="Text" X="25" Y="135" Width="320" Height="20"
                 NoPrefix="yes"
                 Text="Warning: This cannot be undone." />

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back">
          <!-- During install: go back to BusinessSetupDlg (standalone) or DeployModeDlg (terminal) -->
          <Publish Event="NewDialog" Value="BusinessSetupDlg" Condition="NOT REMOVE~=&quot;ALL&quot; AND DEPLOY_MODE = &quot;standalone&quot;" Order="1" />
          <Publish Event="NewDialog" Value="DeployModeDlg" Condition="NOT REMOVE~=&quot;ALL&quot; AND DEPLOY_MODE = &quot;terminal&quot;" Order="2" />
          <!-- During uninstall: go back to VerifyReadyDlg -->
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="REMOVE~=&quot;ALL&quot;" Order="3" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="Next">
          <!-- During install: proceed to VerifyReadyDlg -->
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="NOT REMOVE~=&quot;ALL&quot;" Order="1" />
          <!-- During uninstall: proceed with removal -->
          <Publish Event="EndDialog" Value="Return" Condition="REMOVE~=&quot;ALL&quot;" Order="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Wire: VerifyReadyDlg "Remove" button goes to DeleteDataDlg during uninstall -->
      <Publish Dialog="VerifyReadyDlg" Control="InstallNoShield" Event="NewDialog" Value="DeleteDataDlg"
               Condition="REMOVE~=&quot;ALL&quot;" Order="9000" />

      <!-- Wire: ExitDialog checkbox fires the launch action -->
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <!-- Install directory -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="BrewBarPOS" />
    </StandardDirectory>

    <!-- Harvest Electron output -->
    <ComponentGroup Id="ElectronFiles" Directory="INSTALLFOLDER">
      <Files Include="..\build\electron\win-unpacked\**" />
    </ComponentGroup>

    <!-- Business settings — collected by the wizard, written to bootstrap.json
         for the API to consume on first startup. NO defaults for credentials:
         the user MUST type them or the install proceeds without an admin and the
         API will fall through to the unauthenticated /api/auth/setup endpoint. -->
    <Property Id="STORE_NAME" Value="BrewBar" Secure="yes" />
    <Property Id="TAX_RATE_PCT" Value="15" Secure="yes" />
    <Property Id="CURRENCY_CODE" Value="SCR" Secure="yes" />

    <!-- Admin account: declared without a value so the wizard's "Next" check
         (ADMIN_X="") evaluates true until the user types something in. There is
         no fall-back to a known credential anywhere in the install pipeline. -->
    <Property Id="ADMIN_NAME" Secure="yes" />
    <Property Id="ADMIN_EMAIL" Secure="yes" />
    <Property Id="ADMIN_PASSWORD" Secure="yes" />
    <Property Id="ADMIN_PIN" Secure="yes" />

    <!--
      Managed C# custom actions live in BrewBar.CustomActions.CA.dll. This is the
      replacement for the cmd.exe / PowerShell heredocs that previously interpolated
      MSI properties straight into a shell command line — those couldn't safely
      handle passwords containing quotes, &amp;, $, %, etc. CustomActionData is a raw
      string passed in-process to the action with no shell of any kind.
    -->
    <Binary Id="BrewBarCustomActionsBinary" SourceFile="$(var.CustomActionsDll)" />

    <!-- Bootstrap.json: admin credentials + business settings for first-launch.
         The API consumes it under a zero-users precondition (BootstrapService)
         and deletes it. Skipped silently by the CA if any credential is blank.

         CustomActionData is built by PrepareBootstrapData (an immediate
         managed CA) which base64-encodes each value before packing. The old
         WiX SetProperty CA used raw [PROPERTY] substitution, which silently
         truncated values containing ';' (CustomActionData's field separator).
         See WriteJsonActions.cs for the rationale. -->
    <CustomAction Id="PrepareBootstrapData"
                  BinaryRef="BrewBarCustomActionsBinary"
                  DllEntry="PrepareBootstrapData"
                  Execute="immediate"
                  Return="check" />
    <CustomAction Id="WriteBootstrapJson"
                  BinaryRef="BrewBarCustomActionsBinary"
                  DllEntry="WriteBootstrapJson"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Deployment.json: Electron mode + API URL. Same base64-packed
         CustomActionData pipeline as bootstrap above. -->
    <CustomAction Id="PrepareDeploymentData"
                  BinaryRef="BrewBarCustomActionsBinary"
                  DllEntry="PrepareDeploymentData"
                  Execute="immediate"
                  Return="check" />
    <CustomAction Id="WriteDeploymentJson"
                  BinaryRef="BrewBarCustomActionsBinary"
                  DllEntry="WriteDeploymentJson"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!--
      Per-install JWT signing key. The published API fail-fasts if Jwt:Secret is
      missing or set to a known placeholder (see IdentityServicesExtensions.
      ValidateJwtSecret), so each install must have its own random key. Idempotent
      via the CA — preserves existing key on MajorUpgrade.
    -->
    <CustomAction Id="PrepareJwtSecretData"
                  BinaryRef="BrewBarCustomActionsBinary"
                  DllEntry="PrepareJwtSecretData"
                  Execute="immediate"
                  Return="check" />
    <CustomAction Id="WriteJwtSecret"
                  BinaryRef="BrewBarCustomActionsBinary"
                  DllEntry="WriteJwtSecret"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />
    <!--
      Optional: delete user data (database) on uninstall.
      Default is OFF — user must explicitly opt in via:
        msiexec /x {ProductCode} DELETE_DATA=1
      or via the checkbox in the uninstall confirmation UI.
    -->
    <Property Id="DELETE_DATA" Value="0" Secure="yes" />

    <CustomAction Id="DeleteUserData"
                  Directory="INSTALLFOLDER"
                  ExeCommand='cmd.exe /c rmdir /s /q "%APPDATA%\brewbar-pos-desktop"'
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Prepare* CAs are immediate managed CAs; they read MSI properties via
           session["X"], base64-encode each value, and write the joined result
           to the property whose name matches the deferred CA (MSI then
           surfaces that string as session.CustomActionData inside the
           sandbox). They must run before the deferred CAs but inside the
           InstallExecute phase. -->
      <Custom Action="PrepareDeploymentData" Before="WriteDeploymentJson" />
      <Custom Action="WriteDeploymentJson" After="InstallFiles" />

      <Custom Action="PrepareBootstrapData" Before="WriteBootstrapJson" Condition="DEPLOY_MODE = &quot;standalone&quot;" />
      <Custom Action="WriteBootstrapJson" After="WriteDeploymentJson" Condition="DEPLOY_MODE = &quot;standalone&quot;" />

      <!-- Always generate a JWT key — the API exe ships in both modes and may be started later -->
      <Custom Action="PrepareJwtSecretData" Before="WriteJwtSecret" />
      <Custom Action="WriteJwtSecret" After="WriteBootstrapJson" />

      <Custom Action="DeleteUserData" After="RemoveFiles" Condition="DELETE_DATA=&quot;1&quot;" />
    </InstallExecuteSequence>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="BrewBarStartMenu" Name="BrewBar POS">
        <Component Id="StartMenuShortcut" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
          <Shortcut Id="BrewBarShortcut"
                    Name="BrewBar POS"
                    Target="[INSTALLFOLDER]BrewBar POS.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RegistryValue Root="HKCU"
                         Key="Software\BrewBar\POS"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
          <RemoveFolder Id="RemoveBrewBarStartMenu" On="uninstall" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Desktop shortcut -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <Shortcut Id="BrewBarDesktopShortcut"
                  Name="BrewBar POS"
                  Target="[INSTALLFOLDER]BrewBar POS.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\BrewBar\POS"
                       Name="desktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Taskbar pin shortcut (placed on desktop with taskbar-pin-friendly name) -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="TaskbarPinHelper" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <Shortcut Id="BrewBarTaskbarShortcut"
                  Name="BrewBar POS - Pin to Taskbar"
                  Description="Drag this shortcut to the taskbar to pin BrewBar POS"
                  Target="[INSTALLFOLDER]BrewBar POS.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\BrewBar\POS"
                       Name="taskbarHelper"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Launch application checkbox on the installer exit dialog -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch BrewBar POS" />
    <Property Id="WixShellExecTarget" Value="[INSTALLFOLDER]BrewBar POS.exe" />
    <CustomAction Id="LaunchApplication"
                  DllEntry="WixShellExec"
                  Impersonate="yes"
                  BinaryRef="Wix4UtilCA_X86" />

    <!-- Features shown in the feature-tree UI -->
    <Feature Id="MainApplication" Title="BrewBar POS" Description="Core application files (required)."
             Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="ElectronFiles" />
    </Feature>

    <Feature Id="StartMenuShortcutFeature" Title="Start Menu Shortcut"
             Description="Add a shortcut to the Windows Start Menu." Level="1" AllowAbsent="yes">
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Feature Id="DesktopShortcutFeature" Title="Desktop Shortcut"
             Description="Add a shortcut to the Desktop." Level="1" AllowAbsent="yes">
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <Feature Id="TaskbarPinFeature" Title="Taskbar Pin Helper"
             Description="Place a helper shortcut on the Desktop that you can drag to the taskbar."
             Level="2" AllowAbsent="yes">
      <ComponentRef Id="TaskbarPinHelper" />
    </Feature>

  </Package>
</Wix>

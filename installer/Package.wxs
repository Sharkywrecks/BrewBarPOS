<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="BrewBar POS"
           Manufacturer="BrewBar"
           Version="$(var.ProductVersion)"
           UpgradeCode="8F4E2A1B-3C5D-4E6F-A7B8-9C0D1E2F3A4B"
           Compressed="yes"
           InstallerVersion="500"
           Scope="perMachine">

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of BrewBar POS is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Close running BrewBar processes before install/upgrade/uninstall -->
    <util:CloseApplication Id="CloseBrewBarPOS"
                           Target="BrewBar POS.exe"
                           RebootPrompt="no"
                           CloseMessage="yes" />
    <util:CloseApplication Id="CloseBrewBarAPI"
                           Target="BrewBar.API.exe"
                           RebootPrompt="no"
                           CloseMessage="yes" />

    <!-- Install wizard UI with feature tree (lets users pick shortcuts) -->
    <ui:WixUI Id="WixUI_FeatureTree" />

    <!-- License (required by WixUI_FeatureTree) -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!--
      Custom uninstall dialog: shows a checkbox to optionally delete user data.
      Inserts between the standard VerifyReadyDlg back-navigation during removal.
    -->
    <UI>
      <!-- ================================================================
           INSTALL: Menu Import dialog — optional .xlsx file selection
           Shown after FeaturesDlg, before VerifyReadyDlg during install.
           ================================================================ -->
      <Dialog Id="MenuImportDlg" Width="370" Height="270" Title="BrewBar POS — Menu Import">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Import Your Menu" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="Optionally import your menu from an Excel file (.xlsx)." />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <Control Id="Intro" Type="Text" X="25" Y="55" Width="320" Height="25"
                 NoPrefix="yes"
                 Text="If you have a menu spreadsheet, browse for it below. Leave blank to start with the sample menu. A template is included in the install folder." />

        <Control Id="FormatTitle" Type="Text" X="25" Y="85" Width="320" Height="12"
                 NoPrefix="yes" Text="Expected Excel format (3 sheets):" />

        <Control Id="FormatDetails" Type="Text" X="25" Y="98" Width="320" Height="60"
                 NoPrefix="yes"
                 Text="Sheet 'Products': Category | Product Name | Description | Price | Available&#13;&#10;Sheet 'Modifiers': Modifier Name | Required | Allow Multiple | Option Name | Option Price&#13;&#10;Sheet 'Product Modifiers': Product Name | Modifier Name&#13;&#10;&#13;&#10;A ready-to-fill template (menu-template.xlsx) will be placed in the install directory." />

        <Control Id="FileLabel" Type="Text" X="25" Y="168" Width="320" Height="12"
                 NoPrefix="yes" Text="Menu file path (optional):" />

        <Control Id="MenuFilePath" Type="PathEdit" X="25" Y="182" Width="275" Height="18"
                 Property="MENU_FILE" />
        <Control Id="BrowseBtn" Type="PushButton" X="305" Y="182" Width="45" Height="18" Text="Browse">
          <Publish Property="_BrowseProperty" Value="MENU_FILE" Order="1" />
          <Publish Event="SpawnDialog" Value="BrowseDlg" Order="2" />
        </Control>

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back">
          <Publish Event="NewDialog" Value="CustomizeDlg" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="Next">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Wire MenuImportDlg into install sequence:
           CustomizeDlg (features) -> Next -> MenuImportDlg -> Next -> VerifyReadyDlg
           Only during install (not removal). -->
      <Publish Dialog="CustomizeDlg" Control="Next" Event="NewDialog" Value="MenuImportDlg"
               Condition="NOT REMOVE~=&quot;ALL&quot;" Order="1" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MenuImportDlg"
               Condition="NOT REMOVE~=&quot;ALL&quot;" Order="1" />

      <!-- ================================================================
           UNINSTALL: Delete Data dialog — checkbox to wipe user data
           Shown after VerifyReadyDlg during removal.
           ================================================================ -->
      <Dialog Id="DeleteDataDlg" Width="370" Height="270" Title="BrewBar POS — Uninstall Options">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Remove BrewBar POS" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="20"
                 Transparent="yes" NoPrefix="yes"
                 Text="Click Remove to uninstall BrewBar POS. Your data is kept by default." />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <Control Id="Info" Type="Text" X="25" Y="60" Width="320" Height="40"
                 NoPrefix="yes"
                 Text="The database containing your orders, menu, and settings is stored in your AppData folder. Check the box below to permanently delete it." />

        <Control Id="DeleteDataCheck" Type="CheckBox" X="25" Y="110" Width="320" Height="18"
                 Property="DELETE_DATA" CheckBoxValue="1"
                 Text="Delete all application data (orders, menu, settings)" />

        <Control Id="Warning" Type="Text" X="25" Y="135" Width="320" Height="20"
                 NoPrefix="yes"
                 Text="Warning: This cannot be undone." />

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" />
        </Control>
        <Control Id="Remove" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 ElevationShield="yes" Default="yes" Text="Remove">
          <Publish Event="EndDialog" Value="Return" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Wire: VerifyReadyDlg "Remove" button goes to our dialog instead of proceeding -->
      <Publish Dialog="VerifyReadyDlg" Control="InstallNoShield" Event="NewDialog" Value="DeleteDataDlg"
               Condition="REMOVE~=&quot;ALL&quot;" Order="1" />
    </UI>

    <!-- Install directory -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="BrewBarPOS" />
    </StandardDirectory>

    <!-- Harvest Electron output -->
    <ComponentGroup Id="ElectronFiles" Directory="INSTALLFOLDER">
      <Files Include="..\build\electron\win-unpacked\**" />
    </ComponentGroup>

    <!-- Menu template bundled in install directory -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="MenuTemplate" Guid="D4E5F6A7-B8C9-0123-DEF0-234567890ABC">
        <File Id="MenuTemplateFile"
              Source="..\server\src\BrewBar.API\Resources\menu-template.xlsx"
              Name="menu-template.xlsx" />
        <RegistryValue Root="HKCU"
                       Key="Software\BrewBar\POS"
                       Name="menuTemplate"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!--
      Optional menu import: pass MENU_FILE on command line to import a menu on first launch.
      Example: msiexec /i BrewBar.Installer.msi MENU_FILE="C:\Users\me\my-menu.xlsx"
      The file is copied into the API resources directory as menu-import.xlsx.
      The Electron app detects it on first launch and imports it via the API.
    -->
    <Property Id="MENU_FILE" Secure="yes" />
    <SetProperty Id="MENU_FILE_DEST" After="CostFinalize" Value="[INSTALLFOLDER]resources\api\menu-import.xlsx" />

    <CustomAction Id="CopyMenuFile"
                  Directory="INSTALLFOLDER"
                  ExeCommand='cmd.exe /c if not "[MENU_FILE]"=="" copy /Y "[MENU_FILE]" "[INSTALLFOLDER]resources\api\menu-import.xlsx"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!--
      Optional: delete user data (database) on uninstall.
      Default is OFF — user must explicitly opt in via:
        msiexec /x {ProductCode} DELETE_DATA=1
      or via the checkbox in the uninstall confirmation UI.
    -->
    <Property Id="DELETE_DATA" Value="0" Secure="yes" />

    <CustomAction Id="DeleteUserData"
                  Directory="INSTALLFOLDER"
                  ExeCommand='cmd.exe /c rmdir /s /q "%APPDATA%\BrewBarPOS"'
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="CopyMenuFile" After="InstallFiles" Condition="MENU_FILE" />
      <Custom Action="DeleteUserData" After="RemoveFiles" Condition="REMOVE~=&quot;ALL&quot; AND DELETE_DATA=&quot;1&quot;" />
    </InstallExecuteSequence>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="BrewBarStartMenu" Name="BrewBar POS">
        <Component Id="StartMenuShortcut" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
          <Shortcut Id="BrewBarShortcut"
                    Name="BrewBar POS"
                    Target="[INSTALLFOLDER]BrewBar POS.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RegistryValue Root="HKCU"
                         Key="Software\BrewBar\POS"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
          <RemoveFolder Id="RemoveBrewBarStartMenu" On="uninstall" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Desktop shortcut -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <Shortcut Id="BrewBarDesktopShortcut"
                  Name="BrewBar POS"
                  Target="[INSTALLFOLDER]BrewBar POS.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\BrewBar\POS"
                       Name="desktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Taskbar pin shortcut (placed on desktop with taskbar-pin-friendly name) -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="TaskbarPinHelper" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <Shortcut Id="BrewBarTaskbarShortcut"
                  Name="BrewBar POS - Pin to Taskbar"
                  Description="Drag this shortcut to the taskbar to pin BrewBar POS"
                  Target="[INSTALLFOLDER]BrewBar POS.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\BrewBar\POS"
                       Name="taskbarHelper"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Features shown in the feature-tree UI -->
    <Feature Id="MainApplication" Title="BrewBar POS" Description="Core application files (required)."
             Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="ElectronFiles" />
      <ComponentRef Id="MenuTemplate" />
    </Feature>

    <Feature Id="StartMenuShortcutFeature" Title="Start Menu Shortcut"
             Description="Add a shortcut to the Windows Start Menu." Level="1" AllowAbsent="yes">
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Feature Id="DesktopShortcutFeature" Title="Desktop Shortcut"
             Description="Add a shortcut to the Desktop." Level="1" AllowAbsent="yes">
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <Feature Id="TaskbarPinFeature" Title="Taskbar Pin Helper"
             Description="Place a helper shortcut on the Desktop that you can drag to the taskbar."
             Level="2" AllowAbsent="yes">
      <ComponentRef Id="TaskbarPinHelper" />
    </Feature>

  </Package>
</Wix>
